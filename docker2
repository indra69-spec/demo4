# Build the Java app
FROM maven:3.8.4-openjdk-11-slim AS build
WORKDIR /app
COPY pom.xml .
COPY src ./src
RUN mvn clean package

# Run the Java app
FROM openjdk:11-jre-slim
WORKDIR /app
COPY --from=build /app/target/simple-java-app-1.0-SNAPSHOT.jar app.jar
EXPOSE 9090
ENTRYPOINT ["java", "-jar", "app.jar"]

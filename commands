sudo apt update
sudo apt install openjdk-21-jdk maven git docker.io -y
java -version
mvn -version
docker --version

mvn archetype:generate -DgroupId=org.example -DartifactId=Demo2 \
  -DarchetypeArtifactId=maven-archetype-quickstart \
  -DarchetypeVersion=1.4 -DinteractiveMode=false

cd Demo2

find . -name "*.java"
This should show src/main/java/org/example/App.java. If it shows a different class name, note it — you'll swap it into pom.xml 

mvn clean package
ls target/
java -jar target/demo2.jar
This must print output with no errors before moving forward. If App.java prints Hello World!, you'll see that.

